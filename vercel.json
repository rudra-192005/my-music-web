{
  "version": 2,
  "name": "sonix-music-player",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "scripts/**/*.js",
      "use": "@vercel/static"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/player",
      "dest": "/index.html"
    },
    {
      "src": "/queue",
      "dest": "/queue.html"
    },
    {
      "src": "/playlist",
      "dest": "/playlist.html"
    },
    {
      "src": "/playlists",
      "dest": "/playlist.html"
    },
    {
      "src": "/userdata",
      "dest": "/userdata.html"
    },
    {
      "src": "/profile",
      "dest": "/userdata.html"
    },
    {
      "src": "/recommendations",
      "dest": "/recommendations.html"
    },
    {
      "src": "/discover",
      "dest": "/recommendations.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/styles/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
